# Reel Automation — local LLM configuration.
# Copy this file to `.env` and paste your key. `.env` is gitignored; this
# `.env.example` is the committed template. All vars use the REEL_AUTOMATION_
# prefix and are read by app/core/config.py (Settings).

# --- Provider routing (CLAUDE.md §6) ---------------------------------------
# The OpenAI-compatible adapter speaks any compatible backend; switch providers
# by changing base_url + key + model only (no code change).
REEL_AUTOMATION_DEFAULT_PROVIDER=openai-compatible

# --- Groq (recommended free tier: fast, no credit card required) -----------
REEL_AUTOMATION_BASE_URL=https://api.groq.com/openai/v1
REEL_AUTOMATION_API_KEY=gsk_paste_your_groq_key_here
# Verify the current model id at https://console.groq.com/docs/models
REEL_AUTOMATION_PLANNING_MODEL=llama-3.3-70b-versatile
REEL_AUTOMATION_EXTRACTION_MODEL=llama-3.3-70b-versatile
REEL_AUTOMATION_LONG_CONTEXT_MODEL=llama-3.3-70b-versatile
REEL_AUTOMATION_FALLBACK_MODEL=llama-3.1-8b-instant

# --- Alternatives (same adapter — just swap base_url + key + model) ---------
# OpenRouter:   REEL_AUTOMATION_BASE_URL=https://openrouter.ai/api/v1
#               (key sk-or-...; many ":free" model ids)
# Together AI:  REEL_AUTOMATION_BASE_URL=https://api.together.xyz/v1
# Local Ollama: REEL_AUTOMATION_BASE_URL=http://localhost:11434/v1
#               (REEL_AUTOMATION_API_KEY can be any non-empty string)

# --- Named provider presets (ADR 0028) -------------------------------------
# app.services.llm.providers maps a backend NAME -> its known base_url, so you
# can build a provider with build_provider("groq", settings) without pasting a
# URL. Each preset reads only its key from below (the base_url is the preset);
# per-role models stay set by the *_MODEL vars above. Set just the one(s) you use.
# Known names: groq, nvidia, huggingface, ollama.
REEL_AUTOMATION_GROQ_API_KEY=gsk_paste_your_groq_key_here
REEL_AUTOMATION_NVIDIA_API_KEY=nvapi_paste_your_nvidia_build_key_here
REEL_AUTOMATION_HUGGINGFACE_API_KEY=hf_paste_your_huggingface_token_here
# Ollama is local and needs no key (any bearer token is accepted).

# --- Search fabric (CLAUDE.md §4, ADR 0013/0021) ---------------------------
# `SEARCH_PROVIDER` selects the wired adapter: "tavily" (reads SEARCH_API_KEY)
# or "brave" (reads BRAVE_API_KEY). Search keys are separate from the LLM key so
# the two are configured independently.
REEL_AUTOMATION_SEARCH_PROVIDER=tavily
# Tavily — free tier, no card. Get a key at https://app.tavily.com (tvly-...).
REEL_AUTOMATION_SEARCH_API_KEY=tvly_paste_your_tavily_key_here
# Brave — used when SEARCH_PROVIDER=brave. https://brave.com/search/api/
REEL_AUTOMATION_BRAVE_API_KEY=paste_your_brave_key_here

# --- Media production fabric (end-to-end video pipeline, ADR 0032) ---------
# Needed only for a *live* render (the hermetic tests use fakes). A live run also
# requires the `ffmpeg` binary on PATH (which also installs `ffprobe`; ADR 0023).
#
# TTS: the adapter (`HttpTtsProvider`, ADR 0022) speaks ONE generic REST contract,
# not a vendor SDK:
#   POST {TTS_BASE_URL}/synthesize  with  Authorization: Bearer {TTS_API_KEY}
#     body: {"text": "...", "voice": "..."}
#     -> response body = raw audio bytes; X-Audio-Duration-Ms header = clip ms
# Point it at any endpoint that speaks this (a hosted TTS that matches it, or a
# tiny self-hosted shim in front of a free engine such as Coqui/Piper/ElevenLabs).
# Both vars must be set for a live render or `make video` fails loud.
REEL_AUTOMATION_TTS_BASE_URL=https://your-tts-endpoint.example.com
REEL_AUTOMATION_TTS_API_KEY=paste_your_tts_key_here
REEL_AUTOMATION_TTS_VOICE=narrator
# Stock B-roll (Pexels Videos API, ADR 0024): required for a real composition —
# ffmpeg needs >= 1 visual. Without it the live render fails loud. Free key (no
# card) at https://www.pexels.com/api/.
REEL_AUTOMATION_STOCK_API_KEY=paste_your_pexels_key_here
# Where rendered audio + video artifacts are written (relative to backend/ →
# backend/renders). The finished video lands here as vid_*.mp4.
REEL_AUTOMATION_MEDIA_OUTPUT_DIR=renders
