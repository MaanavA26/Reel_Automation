# Reel Automation — local LLM configuration.
# Copy this file to `.env` and paste your key. `.env` is gitignored; this
# `.env.example` is the committed template. All vars use the REEL_AUTOMATION_
# prefix and are read by app/core/config.py (Settings).

# --- Provider routing (CLAUDE.md §6) ---------------------------------------
# The OpenAI-compatible adapter speaks any compatible backend; switch providers
# by changing base_url + key + model only (no code change).
REEL_AUTOMATION_DEFAULT_PROVIDER=openai-compatible

# --- Groq (recommended free tier: fast, no credit card required) -----------
REEL_AUTOMATION_BASE_URL=https://api.groq.com/openai/v1
REEL_AUTOMATION_API_KEY=gsk_paste_your_groq_key_here
# Verify the current model id at https://console.groq.com/docs/models
REEL_AUTOMATION_PLANNING_MODEL=llama-3.3-70b-versatile
REEL_AUTOMATION_EXTRACTION_MODEL=llama-3.3-70b-versatile
REEL_AUTOMATION_LONG_CONTEXT_MODEL=llama-3.3-70b-versatile
REEL_AUTOMATION_FALLBACK_MODEL=llama-3.1-8b-instant

# --- Alternatives (same adapter — just swap base_url + key + model) ---------
# OpenRouter:   REEL_AUTOMATION_BASE_URL=https://openrouter.ai/api/v1
#               (key sk-or-...; many ":free" model ids)
# Together AI:  REEL_AUTOMATION_BASE_URL=https://api.together.xyz/v1
# Local Ollama: REEL_AUTOMATION_BASE_URL=http://localhost:11434/v1
#               (REEL_AUTOMATION_API_KEY can be any non-empty string)

# --- Search fabric (CLAUDE.md §4, ADR 0013) --------------------------------
# The live `SearchProvider` adapter (Tavily) — separate key from the LLM above
# so search and the model are configured independently. Free tier, no card.
# Get a key at https://app.tavily.com (format: tvly-...).
REEL_AUTOMATION_SEARCH_API_KEY=tvly_paste_your_tavily_key_here
